# Pipeline configuration for benchmark runs.
#
# This file defines all settings for both run-local.sh (Docker) and
# run-aci.sh (Azure Container Instances). Lines starting with '#' are
# comments. Blank lines are ignored.
#
# Sections:
#   (top-level)         Global settings shared by all environments
#   [docker]            Docker-specific settings (used by run-local.sh)
#   [aci]               ACI-specific settings (used by run-aci.sh)
#   [database_engines]  Engines to benchmark against (name=connection_string)
#   [benchmarks]        Benchmark YAML configs to run, one per line
#
# Benchmarks are run serially: for each engine, all benchmarks execute
# in order. Results are organized by engine under the run directory.

# --- Global settings (shared by all environments) ---
cpu=2
memory=4g
results_dir=./results

# Locust concurrency overrides (optional).
# When set, these override the per-benchmark YAML config values.
# Leave commented out to use the defaults from each benchmark's YAML config.
# users=10
# spawn_rate=5
# run_time=60s

# Extra arguments passed to bench-run (optional, space-separated)
extra_args=

# --- Docker settings (used by run-local.sh) ---
[docker]
network=auto
skip_build=false

# --- ACI settings (used by run-aci.sh) ---
[aci]
resource_group=benchmarks-rg
location=eastus
# acr_name=myregistry    # leave empty to auto-create
cleanup=false

# Database engines to benchmark against.
# Format: engine_name=mongodb_connection_string
# Benchmarks will run against each engine in order.
[database_engines]
#mongodb=mongodb://mongodb:27017
# atlas=mongodb+srv://user:pass@cluster.mongodb.net
# azure_documentdb=mongodb://user:pass@myaccount.mongo.cosmos.azure.com:10255/?ssl=true
# aws_documentdb=mongodb://user:pass@docdb-cluster.region.docdb.amazonaws.com:27017/?ssl=true

# Benchmark configs to run, one per line.
# These reference YAML files in the config/ directory.
[benchmarks]
insert/insert_no_index.yaml
insert/insert_single_path_index.yaml
insert/insert_wildcard_index.yaml
insert/insert_composite_index.yaml
insert/insert_unique_index.yaml